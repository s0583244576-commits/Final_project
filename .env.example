# ─── Tessera vendor mock — replay + chaos configuration ─────────────────────
#
# These env vars are read by the tlc-publisher service at startup (see
# compose.yml). Restart `tlc-publisher` after editing to pick up changes:
#   docker compose restart tlc-publisher
# Or use the dedicated Make targets:
#   make vendor-chaos    # turn late-correction chaos on
#   make vendor-calm     # turn it off
# ────────────────────────────────────────────────────────────────────────────

# Replay speed: how many wall-clock seconds map to one simulated month.
# Default 75 → four months drip in ~5 wall-minutes (the demo budget).
# Raise (e.g. 300) to slow it down for debugging; lower for a faster sanity loop.
REPLAY_SECONDS_PER_MONTH=75

# Inclusive window of HV-FHV monthly drops to replay. The CloudFront mirror
# serves 2019-02 onwards; the default 4-month autumn-into-holidays window
# gives hotspot and seasonality signal. ~2 GB of parquet total.
REPLAY_WINDOW_START=2024-09
REPLAY_WINDOW_END=2024-12

# ─── Chaos (calm defaults; flip with `make vendor-chaos`) ───────────────────

# Probability per chaos roll that a previously-published file is re-PUT
# with a small deterministic mutation (a few rows have their
# base_passenger_fare nudged). The parquet is genuinely rewritten so MinIO
# returns a new ETag. Realistic: 0.2-0.5.
VENDOR_LATE_CORRECTION_RATE=0

# How often (in simulated days) the publisher rolls for a late-correction.
# Independent of publication boundaries — rolls keep firing after every
# month is in the bucket. Default 5 sim-days ≈ 12 wall-seconds at the
# default replay speed.
VENDOR_CHAOS_CHECK_SIM_DAYS=5

# ─── MinIO credentials ──────────────────────────────────────────────────────
# Students use these as the S3 access-key / secret-key when configuring
# boto3 or pyspark s3a against http://localhost:18900.
MINIO_ROOT_USER=tessera
MINIO_ROOT_PASSWORD=tessera-secret

# ─── Host-cache passthrough (optional) ──────────────────────────────────────
# If set to a host directory containing pre-downloaded HV-FHV parquet files
# and/or the zone lookup CSV, `data-init` copies from there instead of
# hitting CloudFront. Saves ~2 GB on every `make reset`. Filenames must
# match exactly:
#   fhvhv_tripdata_YYYY-MM.parquet
#   taxi_zone_lookup.csv
# Leave commented out to download from CloudFront as normal.
# HVFHV_CACHE_DIR=/Users/you/tlc-cache
